# Database
DATABASE_URL="postgresql://user:password@localhost:5432/gamecommunity"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# IGDB API (get from Twitch Developer Console)
IGDB_CLIENT_ID="your-igdb-client-id"
IGDB_CLIENT_SECRET="your-igdb-client-secret"
# Optional: a static token can also be used, but tokens expire quickly.
IGDB_ACCESS_TOKEN="your-igdb-access-token"

# Node environment
NODE_ENV="development"
